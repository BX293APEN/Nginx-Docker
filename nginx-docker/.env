# ==========================================
# .env : compose.yml内で利用する環境変数の設定
# ==========================================

# ==========================================
# プロジェクトの設定
# 
# | 項目 | 内容 | 備考 |
# | --- | --- | --- |
# | COMPOSE_PROJECT_NAME | プロジェクト名 | 全て小文字にすること |
# | VOLUME | コンテナ内でマウントするホストディレクトリ | - |
# 
# ==========================================

COMPOSE_PROJECT_NAME=nginx-docker

VOLUME=./linux_data

TIME_ZONE=Asia/Tokyo
LANG=ja_JP.UTF8

# ==========================================
# Nginxの設定 (nginx)
# 
# | 項目 | 内容 | 備考 |
# | --- | --- | --- |
# | NGINX_CONTAINER_NAME | Nginxのコンテナ名 | 別コンテナ・外部からアクセスする際に使用する |
# | Dockerfile_DIR | Dockerfileがあるディレクトリ | 相対パス |
# | Dockerfile | Dockerfileの名前 | コンテナ起動時に使用 |
# | ENTRY_DIR | Nginxで使用するフォルダ | /${ENTRY_DIR} としてルート直下に作成する (権限問題) |
# | ENTRY_POINT | Dockerfileを使用後実行するスクリプト | - |
# | WS | Nginxの作業スペース | /${ENTRY_DIR}/${WS} にNginxのhtml/config一式をマウントする |
# | USER_NAME | Nginxを起動するユーザ名 | - |
# | PASSWORD | Nginxを起動するユーザのパスワード | - |
# | PORT | 外部からWebアプリにアクセスする際のポート番号 | (localhost|IPアドレス):${PORT} |
# 
# ==========================================

NGINX_CONTAINER_NAME=Docker_Nginx_Linux
Dockerfile_DIR=.
Dockerfile=Dockerfile

ENTRY_DIR=Programs
ENTRY_POINT=start.sh

WS=WS

USER_NAME=PEN
PASSWORD=password

PORT=3000

# ==========================================
# データベースサーバの設定 (db)
# 
# | 項目 | 内容 | 備考 |
# | --- | --- | --- |
# | DB_IMAGE | データベースサーバのコンテナバージョン | - |
# | DB_CONTAINER_NAME | データベースサーバのコンテナ名 | 別コンテナ・外部からアクセスする際に使用する |
# | DB_PORT | Nginxからデータベースサーバにアクセスするためのポート番号 | ${DB_CONTAINER_NAME}:${DB_PORT} |
# | DB_NAME | 使用するデータベース名 | 初回起動時に新規作成 |
# | DB_ROOT_PASSWORD | rootユーザのパスワード | 初回起動時に設定 |
# | DB_USER | データベースをデフォルトで使用するユーザ | 初回起動時に設定 |
# | DB_PASSWORD | ${DB_USER}のパスワード | 初回起動時に設定 |
# 
# ==========================================

DB_IMAGE=mysql:8.4
DB_CONTAINER_NAME=Docker_DB
DB_PORT=3306

DB_NAME=pendb
DB_ROOT_PASSWORD=password
DB_USER=PEN
DB_PASSWORD=pen