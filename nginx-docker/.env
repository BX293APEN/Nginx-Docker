# docker-compose.yml内で利用する環境変数の設定
COMPOSE_PROJECT_NAME=project1           # プロジェクト名(全て小文字)
CONTAINER_NAME=Docker_Linux

Dockerfile_DIR=.
Dockerfile=Dockerfile

VOLUME=./linux_data

TIME_ZONE=Asia/Tokyo
LANG=ja_JP.UTF8

USER_NAME=PEN
PASSWORD=password

ENTRY_DIR=Programs
ENTRY_POINT=start.sh

WS=WS

# --- MySQL (dbコンテナ) 関連 ---
DB_IMAGE=mysql:8.4
DB_CONTAINER_NAME=Docker_MySQL

DB_ROOT_PASSWORD=root_password
DB_NAME=sample_db
DB_USER=sample_user
DB_PASSWORD=sample_password

# linuxコンテナから見た接続先(コンテナ名がそのままホスト名になる)
DB_HOST=Docker_MySQL
DB_PORT=3306